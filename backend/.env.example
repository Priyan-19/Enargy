# ============================================================
# Enargy Backend – Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# Server
PORT=3000

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enargy
DB_USER=postgres
DB_PASSWORD=yourpassword

# API Security
API_KEY=EB_SECURE_KEY_123

# Blockchain (Hardhat local network or any Ethereum-compatible network)
# After deploying contract, paste the contract address below
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0xYourDeployedContractAddress
# Private key of the deployer account (from Hardhat test accounts)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret
